# ─── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── MongoDB ─────────────────────────────────────────────────
# Local:
MONGODB_URI=mongodb://localhost:27017/discord-shop
# MongoDB Atlas (recommended cho hosting):
# MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/discord-shop?retryWrites=true&w=majority

# ─── Session ─────────────────────────────────────────────────
# Tạo chuỗi ngẫu nhiên: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=thay_bang_chuoi_32_ky_tu_ngau_nhien_o_day

# ─── Discord OAuth2 ──────────────────────────────────────────
# Lấy tại: https://discord.com/developers/applications
DISCORD_CLIENT_ID=123456789012345678
DISCORD_CLIENT_SECRET=abcdefghijklmnopqrstuvwxyz123456

# Development:
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback
# Production (thay bằng domain thật):
# DISCORD_CALLBACK_URL=https://yourdomain.com/auth/discord/callback

# ─── Admin ───────────────────────────────────────────────────
# Discord ID của admin (bật Developer Mode → chuột phải user → Copy ID)
# Nhiều admin: phân cách bằng dấu phẩy, KHÔNG có khoảng trắng
ADMIN_IDS=123456789012345678,987654321098765432

# ─── Discord Webhook (tùy chọn) ──────────────────────────────
# Tạo webhook: Channel Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN
